{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DatabaseConnectionString": "data source=localhost;initial catalog=PARS;Integrated Security=true;TrustServerCertificate=true"
  },
  "ArchiveStorage": {
    "ServiceUri": "",
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "payroll-archive"
  },
  "ArchiveSftp": {
    "Host": "",
    "Port": 22,
    "Username": "",
    "ExpectedHostKeySha256": "",
    "ConnectionTimeoutSeconds": 30
  },
  "ArchiveIngestion": {
    "Enabled": false,
    "PollIntervalSeconds": 300,
    "MaxRecordsPerRun": 5000,
    "MetadataRemotePath": "/outbound/pars/archive-metadata.csv",
    "ProcessedDirectory": "/outbound/pars/processed",
    "BlobContainer": "payroll-archive"
  }
}
 
